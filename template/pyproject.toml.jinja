{% if project_kind == "library" -%}
[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

{% endif -%}
[project]
name = "{{ project_name }}"
{% if project_kind == "library" -%}
dynamic = ["version"]
{% else -%}
version = "0.1.0"
{% endif -%}
description = "{{ project_description }}"
readme = "README.md"
license = "MIT"
authors = [{ name = "{{ author_name }}", email = "{{ author_email }}" }]
requires-python = ">={{ python_version }}"
dependencies = []
{% if project_kind == "library" %}
[project.urls]
Homepage = "https://github.com/{{ github_owner }}/{{ project_name }}"
Repository = "https://github.com/{{ github_owner }}/{{ project_name }}"
Issues = "https://github.com/{{ github_owner }}/{{ project_name }}/issues"
{% endif %}
[dependency-groups]
dev = [
    "pytest>=8.0.0",
    "pytest-cov>=7.0.0",
    "mypy>=1.10",
    "pre-commit>=4.0.0",
]

{% if project_kind == "library" -%}
[tool.hatch.version]
path = "src/{{ package_name }}/__init__.py"

[tool.hatch.build.targets.wheel]
packages = ["src/{{ package_name }}"]
{% else -%}
[tool.uv]
package = false
{% endif %}
[tool.ruff]
line-length = 100
src = ["src"]
target-version = "py{{ python_version | replace('.', '') }}"

[tool.ruff.lint]
select = [
    "E",     # pycodestyle errors
    "W",     # pycodestyle warnings
    "F",     # pyflakes
    "I",     # isort
    "UP",    # pyupgrade
    "B",     # flake8-bugbear
    "SIM",   # flake8-simplify
    "D",     # pydocstyle
    "C4",    # flake8-comprehensions
    "PT",    # flake8-pytest-style
    "PIE",   # flake8-pie
    "DTZ",   # flake8-datetimez (timezone-aware datetimes)
    "ISC",   # implicit-str-concat (catches missing commas)
    "ASYNC", # flake8-async
    "N",     # pep8-naming
    "FURB",  # refurb (modernization)
    "RUF",   # ruff-specific rules
    "PLE",   # pylint errors
    "PLW",   # pylint warnings
]
ignore = [
    "E501",   # line-too-long — the formatter owns line length
    "D10",    # missing docstrings — don't force them
    "D415",   # first-line punctuation — the module docstring is the project
    # description, whose punctuation varies
    "ISC001", # single-line implicit concat — conflicts with the formatter
]

[tool.ruff.lint.pydocstyle]
convention = "google"

[tool.ruff.lint.per-file-ignores]
"tests/**" = ["D"] # tests don't need docstring linting

[tool.mypy]
python_version = "{{ python_version }}"
strict = true
ignore_missing_imports = true # third-party libs are often untyped

[tool.pytest.ini_options]
testpaths = ["tests"]
addopts = "-rA --durations=10 --color=yes --cov=src --cov-report=term-missing{% if use_coverage_gate %} --cov-fail-under={{ coverage_floor }}{% endif %}"
{% if project_kind == "app" -%}
pythonpath = ["."]
{% endif -%}
